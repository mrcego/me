{
  "name": "me",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3000",
    "generate": "jiti scripts/write-theme-init.ts && nuxt generate",
    "generate:netlify": "jiti scripts/write-theme-init.ts && nuxt prepare && node --input-type=module -e \"import fs from 'node:fs'; for (const dir of ['.output', 'dist', 'node_modules/.cache/nuxt']) fs.rmSync(dir, { recursive: true, force: true });\" && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,mjs,vue,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,mjs,vue,json,md,yml,yaml}\"",
    "typecheck": "nuxt typecheck",
    "prepush:validate": "pnpm lint && pnpm format:check && pnpm typecheck",
    "avatars:fetch": "node scripts/fetch-avatars.mjs",
    "avatars:scrape": "node scripts/scrape-linkedin-avatars.mjs",
    "og:generate": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.4.1",
    "@nuxtjs/seo": "^5.3.2",
    "@primeuix/themes": "^2.0.3",
    "@resvg/resvg-js": "^2.6.2",
    "@vueuse/core": "^14.3.0",
    "motion-v": "^2.3.0",
    "nuxt": "^4.4.8",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "satori": "^0.28.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.117",
    "@iconify-json/simple-icons": "^1.2.90",
    "@iconify-json/solar": "^1.2.5",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/hints": "^1.1.3",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.3.1",
    "@primevue/nuxt-module": "^4.5.5",
    "@tailwindcss/vite": "^4.3.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vue-tsc": "^3.3.7"
  },
  "pnpm": {
    "overrides": {
      "typescript": "$typescript",
      "sharp": "$sharp",
      "unhead": "^3.1.8",
      "vite": "$vite"
    }
  }
}
